---
import '../styles/global.css';
import Artwork from '../components/Artwork.astro';
import FloorPlan from '../components/FloorPlan.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const title = 'The Blue Hour — an exhibition at Vitrine';
const description =
  'European abstraction between daylight and dark, 1959–1973. Thirty-four works, eleven painters, three rooms. 14 September 2026 — 11 January 2027 at Vitrine.';

/* the key image — hangs on the title wall (still: the walk starts in the rooms) */
const keyWork = {
  kind: 'field',
  artist: 'Aino Vasara (1921–1989)', title: 'The Blue Hour II', year: 1965,
  medium: 'oil on canvas, 130 × 165 cm', lender: 'Kunsthall Vestre, Bergen',
  label: 'Abstract painting: a tall field of cobalt blue, brighter at its heart, sinking to near-black at the base — a sky with no source of light.',
};

/* the walls — three rooms, three works shown from each */
const rooms = [
  {
    id: 'room-i', numeral: 'I', name: 'Approach of Evening', inRoom: 12,
    text: 'Evening does not fall. It approaches — along a horizon, up a wall, across a table left in the window. The earliest works in the exhibition still hold the day’s structure: a band, a frame, a ruled line. What changes is the temperature. Watch the greys lean blue.',
    works: [
      {
        kind: 'bands', depth: 0.08,
        artist: 'Margit Ellø (1913–1998)', title: 'Threshold, Evening', year: 1959,
        medium: 'oil on linen, 97 × 71 cm', lender: 'Private collection, Oslo',
        label: 'Abstract painting: pale horizontal bands of warm grey stacked like a landscape, sinking to a dark base, with one thin cobalt line low in the frame.',
        note: null, portrait: false,
      },
      {
        kind: 'window', depth: -0.035,
        artist: 'Tomas Reig (1927–2001)', title: 'Window at Six', year: 1961,
        medium: 'oil on panel, 88 × 68 cm', lender: 'The Aldersgate Trust',
        label: 'Abstract painting: a large cobalt rectangle floats on an off-white ground, a deeper blue inside it, with a narrow ochre sliver at the right edge.',
        note: 'first public loan', portrait: true,
      },
      {
        kind: 'gesture', depth: 0.045,
        artist: 'Margit Ellø (1913–1998)', title: 'Study for Falling Light', year: 1960,
        medium: 'gouache and pencil on paper, 48 × 63 cm', lender: 'Collection of the artist’s estate',
        label: 'Work on paper: five broad brushstrokes in grey, cobalt and ochre curve downward across a faint pencil grid, like light dropping through the day.',
        note: null, portrait: false,
      },
    ],
  },
  {
    id: 'room-ii', numeral: 'II', name: 'The Blue Hour', inRoom: 11,
    text: 'For a few minutes the sky is brighter than everything beneath it, and every colour narrows toward one. The paintings in this room were made over eight years, in three countries, by painters who never met. They arrived at the same blue.',
    works: [
      {
        kind: 'horizon', depth: 0.075,
        artist: 'Margit Ellø (1913–1998)', title: 'Løvøya, Evening', year: 1966,
        medium: 'oil on linen, 92 × 130 cm', lender: 'Museum Hedeholm, Kiel',
        label: 'Abstract painting: a pale strip of sky at the top gives way to a deep cobalt field, a low dark bar of land crossing the seam between them.',
        note: null, portrait: false,
      },
      {
        kind: 'arcs', depth: -0.035,
        artist: 'Claude Debray (1930–2011)', title: 'Interval', year: 1966,
        medium: 'acrylic on canvas, 120 × 120 cm', lender: 'Private collection, Brussels',
        label: 'Abstract painting: three broken circles in cobalt, grey and near-black overlap on a chalky ground, each stopping short of closing; a short orange arc grazes the largest.',
        note: null, portrait: false,
      },
      {
        kind: 'grid', depth: 0.045,
        artist: 'Aino Vasara (1921–1989)', title: 'Eight Minutes Past', year: 1967,
        medium: 'oil and pencil on canvas, 100 × 140 cm', lender: 'Kunsthall Vestre, Bergen',
        label: 'Abstract painting: a hand-ruled grid of cobalt lines, some stopping short of the edge, with the eighth column washed in a pale blue shadow.',
        note: null, portrait: false,
      },
    ],
  },
  {
    id: 'room-iii', numeral: 'III', name: 'Nocturne', inRoom: 11,
    text: 'What remains when the colour goes is not black. The last room is hung lower and lit lower — the works ask for it. Look longer than feels reasonable. The grid surfaces. The ring completes itself. The dark keeps more than it hides.',
    works: [
      {
        kind: 'nightgrid', depth: 0.08,
        artist: 'Tomas Reig (1927–2001)', title: 'Nocturne with Grid', year: 1971,
        medium: 'oil on canvas, 97 × 130 cm', lender: 'The Aldersgate Trust',
        label: 'Abstract painting: a near-black field crossed by a faint blue grid; a single cell burns warm amber, like one lit window in a dark street.',
        note: null, portrait: false,
      },
      {
        kind: 'eclipse', depth: -0.035,
        artist: 'Margit Ellø (1913–1998)', title: 'Last Colour', year: 1973,
        medium: 'oil on linen, 110 × 110 cm', lender: 'Private collection, Oslo',
        label: 'Abstract painting: a vast dark circle barely separates from a darker ground, rimmed along its lower edge by a thin cobalt arc that brightens at one point.',
        note: 'the painter’s final canvas', portrait: false,
      },
      {
        kind: 'veil', depth: 0.045,
        artist: 'Claude Debray (1930–2011)', title: 'What the Dark Keeps', year: 1972,
        medium: 'acrylic on canvas, 146 × 114 cm', lender: 'Museum Hedeholm, Kiel',
        label: 'Abstract painting: tall translucent veils of blue-grey hang in a dark field, a single thin seam of cobalt burning between two of them.',
        note: null, portrait: true,
      },
    ],
  },
];
---
<!doctype html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<script is:inline>
  document.documentElement.classList.add('js');
  try { var t = localStorage.getItem('vitrine-theme'); if (t) document.documentElement.dataset.theme = t; } catch (e) {}
</script>
<title>{title}</title>
<meta name="description" content={description} />
<meta name="theme-color" content="#f5f3ee" />
<meta name="color-scheme" content="light dark" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect x='4' y='4' width='24' height='24' fill='none' stroke='%233b4de0' stroke-width='3'/%3E%3Crect x='11' y='11' width='10' height='10' fill='%233b4de0'/%3E%3C/svg%3E" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body>
<div class="film" aria-hidden="true"></div>
<a class="skip" href="#main">Skip to content</a>

<header class="nav">
  <a class="brand" href={base} aria-label="Vitrine home">
    <svg class="brand-mark" viewBox="0 0 28 28" aria-hidden="true" focusable="false">
      <rect x="3" y="3" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4" />
      <rect x="10" y="10" width="8" height="8" fill="currentColor" />
    </svg>
    <span class="brand-word">Vitrine</span>
  </a>
  <nav class="nav-links" aria-label="Primary">
    <a href="#works">The works</a>
    <a href="#plan">Floor plan</a>
    <a href="#about">About the show</a>
    <a href={`${base}guide/`}>Guide</a>
    <a class="nav-cta" href="#visit">Plan a visit</a>
    <button id="themeBtn" class="theme-btn" type="button" aria-pressed="false" aria-label="Switch to dark mode" title="Toggle light / dark">
      <svg class="ico-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4.5"/><g stroke-linecap="round"><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1"/></g></svg>
      <svg class="ico-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5Z"/></svg>
    </button>
  </nav>
</header>

<main id="main">

  <!-- ============ hero — the title wall ============ -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-grid">
      <div class="hero-copy">
        <p class="eyebrow mono">[ Vitrine · Galleries II–IV · 14 Sep 2026 — 11 Jan 2027 ]</p>
        <h1 id="hero-title" class="hero-title">
          <span class="line"><span>The <em>Blue</em></span></span>
          <span class="line"><span>Hour</span></span>
        </h1>
        <p class="hero-sub">European abstraction between daylight and dark, 1959–1973.
          Thirty-four works trace how a loose generation of painters stopped painting
          places and began painting a time of day.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="#works">Enter the exhibition</a>
          <a class="btn btn-ghost" href="#plan">Floor plan →</a>
        </div>
        <dl class="hero-facts">
          <div><dt class="mono">Works</dt><dd><span class="c-num" data-to="34">34</span></dd></div>
          <div><dt class="mono">Painters</dt><dd><span class="c-num" data-to="11">11</span></dd></div>
          <div><dt class="mono">Rooms</dt><dd>III</dd></div>
          <div><dt class="mono">Audio guide</dt><dd><span class="c-num" data-to="62">62</span> min</dd></div>
        </dl>
        <p class="hero-scroll mono" aria-hidden="true">scroll — the light is going</p>
      </div>

      <div class="hero-side">
        <figure class="work">
          <div class="frame"><Artwork kind={keyWork.kind} label={keyWork.label} /></div>
          <figcaption class="plaque">
            <span class="plaque-artist mono">{keyWork.artist}</span>
            <span class="plaque-title"><i>{keyWork.title}</i>, {keyWork.year}</span>
            <span class="plaque-medium mono">{keyWork.medium} · {keyWork.lender}</span>
          </figcaption>
        </figure>
        <aside class="wall-label reveal" aria-label="Exhibition details">
          <div class="wl-row"><span class="mono">Dates</span><span>14 September 2026 — 11 January 2027</span></div>
          <div class="wl-row"><span class="mono">Where</span><span>Vitrine, Galleries II–IV, first floor</span></div>
          <div class="wl-row"><span class="mono">Curator</span><span>Ines Halvorsen</span></div>
          <div class="wl-row"><span class="mono">Catalogue</span><span>224 pp., Vitrine Editions, €38</span></div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============ the works — parallax walls ============ -->
  <section id="works" class="works" aria-labelledby="works-h">
    <div class="wrap works-grid">
      <div class="works-main">
        <div class="sec-head">
          <p class="kicker mono reveal">[ The works ]</p>
          <h2 id="works-h" class="reveal">Hung in the order the light leaves.</h2>
          <p class="lede reveal">Nine of the thirty-four works, one wall at a time.
            Walk slowly — the walls move with you.</p>
        </div>

        {rooms.map((room) => (
          <article id={room.id} class="room" aria-labelledby={`${room.id}-h`}>
            <span class="room-wm" aria-hidden="true">{room.numeral}</span>
            <header class="room-head">
              <p class="kicker mono reveal">[ Room {room.numeral} ]</p>
              <h3 id={`${room.id}-h`} class="reveal">{room.name}</h3>
              <p class="wall-text reveal">{room.text}</p>
            </header>
            <div class="wall">
              {room.works.map((w) => (
                <figure class={w.portrait ? 'work work--p' : 'work'} data-depth={w.depth}>
                  <div class="frame"><Artwork kind={w.kind} label={w.label} /></div>
                  <figcaption class="plaque">
                    <span class="plaque-artist mono">{w.artist}</span>
                    <span class="plaque-title"><i>{w.title}</i>, {w.year}</span>
                    <span class="plaque-medium mono">{w.medium} · {w.lender}</span>
                    {w.note && <span class="plaque-note mono">{w.note}</span>}
                  </figcaption>
                </figure>
              ))}
            </div>
          </article>
        ))}
      </div>

      <nav class="room-rail" aria-label="Rooms">
        {rooms.map((room) => (
          <a class="rail-link mono" href={`#${room.id}`} data-room={room.id}
            aria-label={`Room ${room.numeral} — ${room.name}`}>{room.numeral}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- ============ floor plan — the navigator ============ -->
  <section id="plan" class="plan" aria-labelledby="plan-h">
    <div class="wrap plan-grid">
      <div class="plan-copy">
        <p class="kicker mono reveal">[ Floor plan ]</p>
        <h2 id="plan-h" class="reveal">Three rooms, one hour.</h2>
        <p class="lede reveal">The exhibition unfolds in the order the light leaves the sky.
          Choose a room to go to its wall — the blue dot keeps your place as you walk.</p>
        <ol class="plan-list">
          {rooms.map((room) => (
            <li>
              <a class="plan-item reveal" href={`#${room.id}`} data-room={room.id}>
                <span class="pi-num" aria-hidden="true">{room.numeral}</span>
                <span class="pi-body">
                  <strong>{room.name}</strong>
                  <span class="mono">{room.works.length} shown here · {room.inRoom} in the room</span>
                </span>
                <span class="pi-go" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
      <figure class="plan-fig reveal">
        <FloorPlan />
        <figcaption class="plan-cap mono">Galleries II–IV, first floor. Step-free throughout; seating in every room.</figcaption>
      </figure>
    </div>
  </section>

  <!-- ============ about the show ============ -->
  <section id="about" class="about" aria-labelledby="about-h">
    <div class="wrap about-grid">
      <div class="about-copy">
        <p class="kicker mono reveal">[ About the show ]</p>
        <h2 id="about-h" class="reveal">An hour with a body of its own.</h2>
        <p class="reveal">Painters have always kept odd hours. Between 1959 and 1973 — in Oslo
          studios, in a borrowed room above an Antwerp print shop, on the Finnish coast — a loose
          generation of European abstractionists began painting not places or things but a time of
          day: the interval after sunset when light has no source, and colour, briefly, has only
          one name.</p>
        <p class="reveal">They did not know each other. Most never showed together. Yet the
          canvases converge with an insistence that no shared manifesto could explain: the same
          narrowing palette, the same reluctance to let a line close, the same cobalt arrived at
          from three directions.</p>
        <blockquote class="about-pull reveal">The blue hour is not a subject. It is an
          instrument, and eleven painters learned to play it.</blockquote>
        <p class="reveal">The exhibition gathers thirty-four of these works — several reunited
          for the first time since they were dispersed at auction in 1974 — and proposes no
          movement, coins no ism. It makes a smaller claim: that for fifteen years, in different
          countries, painting kept arriving at the same hour. Seen from this distance, the hour
          looks less like a moment than a place. We have tried to hang it like one.</p>
        <p class="about-sign reveal">— Ines Halvorsen, curator</p>
      </div>
      <aside class="about-card reveal" aria-label="Exhibition facts">
        <div class="ac-row"><span class="mono">Organised by</span><span>Vitrine</span></div>
        <div class="ac-row"><span class="mono">Supported by</span><span>The Aldersgate Trust</span></div>
        <div class="ac-row"><span class="mono">Lenders</span><span>9 public · 6 private</span></div>
        <div class="ac-row"><span class="mono">Catalogue</span><span>224 pp., 41 plates</span></div>
        <div class="ac-row"><span class="mono">Audio guide</span><span>62 min, incl. in entry</span></div>
        <div class="ac-row"><span class="mono">Touring to</span><span>nowhere — this hang only</span></div>
      </aside>
    </div>
  </section>

  <!-- ============ plan a visit ============ -->
  <section id="visit" class="visit" aria-labelledby="visit-h">
    <div class="wrap visit-grid">
      <div class="visit-info">
        <p class="kicker mono reveal">[ Plan a visit ]</p>
        <h2 id="visit-h" class="reveal">Come at dusk.</h2>
        <p class="lede reveal">The galleries face west and we hang nothing over the windows.
          Arrive an hour before close and the exhibition finishes outside the glass.</p>
        <dl class="visit-rows reveal">
          <div class="v-row"><dt class="mono">Hours</dt><dd>Tue–Sun 10.00–18.00 · <strong>Thu until 21.00</strong> · Mon closed</dd></div>
          <div class="v-row"><dt class="mono">Tickets</dt><dd>€16 · concessions €9 · under-18s free · Thu evenings pay-what-you-wish</dd></div>
          <div class="v-row"><dt class="mono">Address</dt><dd>Vitrine, Paviljoensgracht 2, The Hague</dd></div>
          <div class="v-row"><dt class="mono">Access</dt><dd>step-free throughout · seating in every room · large-print labels at each door</dd></div>
        </dl>
      </div>
      <div class="visit-form reveal" aria-live="polite">
        <form id="visitForm" novalidate>
          <h3>Timed entry</h3>
          <p class="vf-hint">Entry is timed on the half-hour. Hold a slot and pay at the desk — nothing is charged here.</p>
          <div class="field">
            <label for="vName">Name</label>
            <input id="vName" name="name" type="text" required autocomplete="name" placeholder="Your name" />
          </div>
          <div class="field">
            <label for="vEmail">Email</label>
            <input id="vEmail" name="email" type="email" required autocomplete="email" placeholder="you@example.com" />
          </div>
          <div class="field">
            <label for="vDate">Date</label>
            <input id="vDate" name="date" type="date" required min="2026-09-14" max="2027-01-11" />
          </div>
          <button class="btn btn-primary btn-block" type="submit">Hold my entry</button>
          <p class="visit-fine mono" id="visitFine">Demo form — no booking is made. See the README.</p>
        </form>
      </div>
    </div>
  </section>

</main>

<footer class="footer">
  <div class="wrap foot-top">
    <span class="foot-brand">Vitrine</span>
    <nav class="foot-links" aria-label="Footer">
      <a href="#works">The works</a><a href="#plan">Floor plan</a><a href="#about">About the show</a><a href="#visit">Visit</a><a href={`${base}guide/`}>Guide</a>
    </nav>
  </div>
  <div class="wrap foot-bottom mono">
    <span>© 2026 Vitrine — a design-showcase concept, not a real museum. The exhibition, its painters and its lenders are fiction.</span>
    <span>Designed &amp; built by Parable · <a href={`${base}guide/`}>How this was built →</a></span>
  </div>
</footer>

<script is:inline>
(() => {
  'use strict';
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const clamp = (v, a, b) => Math.min(b, Math.max(a, v));
  const root = document.documentElement;

  /* ---------- theme toggle ---------- */
  const themeBtn = document.getElementById('themeBtn');
  const themeMeta = document.querySelector('meta[name="theme-color"]');
  const syncTheme = () => {
    const dark = root.dataset.theme === 'dark';
    if (!themeBtn) return;
    themeBtn.setAttribute('aria-pressed', String(dark));
    themeBtn.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
    if (themeMeta) themeMeta.setAttribute('content', dark ? '#17161a' : '#f5f3ee');
  };
  syncTheme();
  themeBtn && themeBtn.addEventListener('click', () => {
    root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
    try { localStorage.setItem('vitrine-theme', root.dataset.theme); } catch (e) {}
    syncTheme();
  });

  /* ---------- hero intro ---------- */
  const hero = document.querySelector('.hero');
  requestAnimationFrame(() => hero && hero.classList.add('loaded'));

  /* ---------- reveals ---------- */
  const io = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
    }
  }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
  document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

  /* ---------- counters (markup ships final values; JS rewinds, then counts) ---------- */
  if (!reduce) {
    const nums = document.querySelectorAll('.c-num');
    nums.forEach((el) => { el.textContent = '0'; });
    const cio = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        const el = e.target, to = parseFloat(el.dataset.to);
        cio.unobserve(el);
        const dur = 1300, t0 = performance.now();
        const tick = (t) => {
          const p = clamp((t - t0) / dur, 0, 1);
          el.textContent = String(Math.round(to * (1 - Math.pow(1 - p, 3))));
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    }, { threshold: 0.6 });
    nums.forEach((el) => cio.observe(el));
  }

  /* ============================================================
     Signature 1 — gallery-wall parallax.
     Each framed work carries a data-depth; as you scroll, works
     drift at different rates, like walking past a hung wall.
     Layout positions are measured from offsetTop (transforms
     never pollute them), so there is no feedback loop.
     ============================================================ */
  const workEls = Array.from(document.querySelectorAll('.work[data-depth]'));
  if (workEls.length && !reduce) {
    const works = workEls.map((el) => ({ el, depth: parseFloat(el.dataset.depth) || 0, mid: 0 }));
    const measure = () => {
      for (const w of works) {
        let y = 0, n = w.el;
        while (n) { y += n.offsetTop; n = n.offsetParent; }
        w.mid = y + w.el.offsetHeight / 2;
      }
    };
    let queued = false;
    const drift = () => {
      queued = false;
      const mid = scrollY + innerHeight / 2;
      for (const w of works) {
        const off = clamp((mid - w.mid) * w.depth, -90, 90);
        w.el.style.transform = 'translate3d(0,' + off.toFixed(1) + 'px,0)';
      }
    };
    const queue = () => { if (!queued) { queued = true; requestAnimationFrame(drift); } };
    measure(); drift();
    addEventListener('scroll', queue, { passive: true });
    addEventListener('resize', () => { measure(); queue(); });
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => { measure(); queue(); });
  }

  /* ============================================================
     Signature 2 — the floor-plan navigator.
     Every [data-room] link (plan rooms, list items, rail) scrolls
     to its wall; an IntersectionObserver watching a band across
     the middle of the viewport reports the room you are in, and
     the visitor dot walks the plan to match.
     ============================================================ */
  const roomLinks = Array.from(document.querySelectorAll('[data-room]'));
  const dot = document.getElementById('planDot');
  const dotFor = {};
  document.querySelectorAll('.plan-room[data-dot]').forEach((a) => {
    const p = a.dataset.dot.split(',');
    dotFor[a.dataset.room] = { x: +p[0], y: +p[1] };
  });
  const setCurrent = (id) => {
    for (const l of roomLinks) {
      const cur = l.dataset.room === id;
      l.classList.toggle('is-current', cur);
      if (cur) l.setAttribute('aria-current', 'true');
      else l.removeAttribute('aria-current');
    }
    if (dot && dotFor[id]) dot.style.transform = 'translate(' + dotFor[id].x + 'px,' + dotFor[id].y + 'px)';
  };
  roomLinks.forEach((l) => l.addEventListener('click', (e) => {
    const target = document.getElementById(l.dataset.room);
    if (!target) return;
    e.preventDefault();
    setCurrent(l.dataset.room);
    target.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
    history.replaceState(null, '', '#' + l.dataset.room);
  }));
  const roomSecs = ['room-i', 'room-ii', 'room-iii']
    .map((id) => document.getElementById(id)).filter(Boolean);
  if (roomSecs.length) {
    const rio = new IntersectionObserver((entries) => {
      for (const e of entries) if (e.isIntersecting) setCurrent(e.target.id);
    }, { rootMargin: '-35% 0px -55% 0px', threshold: 0 });
    roomSecs.forEach((s) => rio.observe(s));
    setCurrent('room-i');
  }

  /* ---------- timed-entry demo form ---------- */
  const form = document.getElementById('visitForm');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const fields = ['vName', 'vEmail', 'vDate'].map((id) => document.getElementById(id));
      for (const f of fields) {
        if (!f.checkValidity()) { f.reportValidity(); return; }
      }
      const date = fields[2].value;
      form.innerHTML =
        '<div class="visit-done"><strong>Held.</strong>' +
        '<span>Your timed entry for ' + date + ' is waiting at the desk. Come at dusk if you can.</span>' +
        '<span class="mono">demo only — no booking was made. see the readme.</span></div>';
    });
  }
})();
</script>
</body>
</html>
